      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "4edcaa34-b550-4f98-a228-959e372413ba"
      }
    },
    "owner": "darksinnn"
  }
